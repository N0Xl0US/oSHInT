# oSHint environment template
# Copy to .env for local use and fill in real values.
# Never commit your real .env.

# ---------------------------
# API server
# ---------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ---------------------------
# Kafka
# ---------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=osint.raw.maigret.v1
KAFKA_PROBE_TOPIC=osint.probe.maigret.v1
KAFKA_ACKS=all
KAFKA_COMPRESSION=snappy
KAFKA_RETRIES=5
KAFKA_RETRY_BACKOFF_MS=300
KAFKA_LINGER_MS=10
KAFKA_BATCH_NUM_MESSAGES=100
KAFKA_IDEMPOTENCE=true
KAFKA_FLUSH_TIMEOUT=15.0

# ---------------------------
# Core Maigret runtime
# ---------------------------
MAIGRET_BINARY=maigret
MAIGRET_RETRIES=1
MAIGRET_SUBPROCESS_TIMEOUT=120

# ---------------------------
# Orchestrator thresholds/timeouts
# ---------------------------
MAIGRET_TIMEOUT=120
ACADEMIC_TIMEOUT=30
GITHUB_TIMEOUT=20
GITHUB_OCTOSUITE_TIMEOUT=45
BLACKBIRD_TIMEOUT=240
SPIDERFOOT_TIMEOUT=120
HOLEHE_TIMEOUT=45
H8MAIL_TIMEOUT=60
LINKEDIN_TIMEOUT=45

MIN_CONFIDENCE_MAIGRET=0.3
MIN_CONFIDENCE_ACADEMIC=0.3
MIN_CONFIDENCE_GITHUB=0.35
MIN_CONFIDENCE_GITHUB_OCTOSUITE=0.35
MIN_CONFIDENCE_BLACKBIRD=0.45
MIN_CONFIDENCE_SPIDERFOOT=0.45
MIN_CONFIDENCE_HOLEHE=0.45
MIN_CONFIDENCE_H8MAIL=0.45
MIN_CONFIDENCE_LINKEDIN=0.45
RESOLVED_TOPIC=identity.resolved

# ---------------------------
# Academic source settings
# ---------------------------
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
OPENALEX_BASE_URL=https://api.openalex.org
OPENALEX_MAILTO=you@example.com
ORCHID_BASE_URL=https://pub.orcid.org/v3.0
ORCHID_TOKEN_URL=https://orcid.org/oauth/token
ORCHID_SCOPE=/read-public
ORCHID_CLIENT_ID=
ORCHID_CLIENT_SECRET=

# Legacy aliases also accepted by code:
# ORCHID_Client_ID=
# ORCHID_Client_Secret=
# ORCID_CLIENT_ID=
# ORCID_CLIENT_SECRET=

ACADEMIC_REQUEST_TIMEOUT=15
ACADEMIC_MAX_AUTHORS=5
ACADEMIC_MIN_CONFIDENCE=0.3
ACADEMIC_KAFKA_TOPIC=osint.raw.academic.v1

# ---------------------------
# Resolver settings
# ---------------------------
MATCH_THRESHOLD=0.85
CLUSTER_THRESHOLD=0.75
MIN_CLAIMS_FOR_SPLINK=5
CONFIDENCE_DIRECT_INGEST=0.85
CONFIDENCE_FLAG_INGEST=0.60
CONFIDENCE_QUARANTINE=0.40
QUARANTINE_TOPIC=identity.quarantine
PII_HMAC_SECRET=change-me-to-a-long-random-secret

# ---------------------------
# Agent settings (Groq)
# ---------------------------
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.1
GROQ_MAX_TOKENS=1024
OSINT_SERVER_URL=http://localhost:8000
REQUEST_TIMEOUT=300
MAX_TOOL_ROUNDS=5
MAX_TOTAL_SEARCHES=10
MAX_REQUERY_ATTEMPTS=1

# ---------------------------
# Source binaries/tools
# ---------------------------
HOLEHE_BINARY=/absolute/path/to/holehe
BLACKBIRD_BINARY=/absolute/path/to/blackbird.py
BLACKBIRD_ROOT=/absolute/path/to/blackbird
SPIDERFOOT_BINARY=/absolute/path/to/spiderfoot-wrapper.sh
SPIDERFOOT_MODULES=sfp_socialprofiles

# ---------------------------
# LinkedIn source
# ---------------------------
LINKEDIN_LI_AT=your_linkedin_li_at_cookie
LINKEDIN_SESSION_PATH=./linkedin_session.json
LINKEDIN_DAILY_LIMIT=50
LINKEDIN_HEADLESS=true
LINKEDIN_MIN_DELAY=3
LINKEDIN_MAX_DELAY=8
LINKEDIN_SCRAPE_TIMEOUT=15

# ---------------------------
# GitHub source (important for API rate limits)
# ---------------------------
GITHUB_API_TOKEN=ghp_your_github_personal_access_token
